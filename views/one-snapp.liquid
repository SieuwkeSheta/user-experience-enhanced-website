{% render 'partials/head.liquid',
  title: 'Snapp',
  one_Snapp: true,
  OneSnapps: OneSnapps,
  Likescounts: Likescounts,
  Tomatocounts: Tomatocounts,
  Starcounts: Starcounts
%}

<section class="one-snapp-page">
  {% for OneSnapp in OneSnapps %}
    <h2 class="group-name-in-snappmap-or-snapp">
      <svg viewBox="0 0 40 36" xmlns="http://www.w3.org/2000/svg" height="30">
        <title>Go to your groups</title>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M36.455 17.2464C36.455 20.4113 33.8721 22.9873 30.6992 22.9873C27.5268 22.9873 24.9531 20.4113 24.9531 17.2464C24.9531 14.0682 27.5268 11.4922 30.6992 11.4922C33.8653 11.4922 36.455 14.0728 36.455 17.2464ZM13.3312 0C8.64634 0 4.82779 3.81168 4.82779 8.50052C4.82779 13.1888 8.64233 17.0073 13.3312 17.0073C18.0217 17.0073 21.8368 13.1888 21.8368 8.50052C21.8397 3.81168 18.0212 0 13.3312 0ZM39.8847 34.6843C39.8847 29.4545 35.7557 25.2099 30.6906 25.2099C29.7871 25.2099 28.9243 25.3878 28.1032 25.6394C29.185 27.8083 29.8472 30.227 29.8472 32.8287V36H39.8853V34.6843H39.8847ZM0 36H26.6601V32.9848C26.6601 25.4221 20.6761 19.2694 13.3312 19.2694C5.97427 19.2694 0.00057181 25.4227 0.00057181 32.9848V36H0Z" fill=""/>
      </svg>
      {{ OneSnapp.snapmap.groups[0].snappthis_group_uuid.name }}
    </h2>

    <img src="https://fdnd-agency.directus.app/assets/{{ OneSnapp.picture }}?width=500" alt="" width="200">

    <div>
      <a href="/snappmaps/{{OneSnapp.snapmap.name}}">{{ OneSnapp.snapmap.name }}</a>
      <a href="#">{{ OneSnapp.author.name }}</a>
      <a href="/snapps/location/{{ OneSnapp.location }}">{{ OneSnapp.location }}</a>
      <p>{{ OneSnapp.date_created | date: '%d %B %Y %H:%M' | capitalize }}</p>
    </div>
  {% endfor %}
</section>

{% render 'partials/foot.liquid' %}
