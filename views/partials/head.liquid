<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    
    <link rel="stylesheet" href="/styles/style.css">
    <script defer src="/scripts/client.js" type="module"></script>
  </head>
  <body> 

    {% comment %} index.liquid {% endcomment %}
    {% if Home%}
        <header>
          <h1>Home</h1>
        </header>
      {% comment %} groups.liquid {% endcomment %}
      {% elsif MultipleGroups %}
        <header class="items-2-top-nav-bar">
          <h1>Your groups</h1>
          <button>
            <svg height="30" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
              <title>Add group</title>
              <path id="Shape" fill-rule="evenodd" clip-rule="evenodd" d="M36 20.5714H20.5714V36H15.4286V20.5714H0V15.4286H15.4286V0H20.5714V15.4286H36V20.5714V20.5714Z" fill=""/>
            </svg>
          </button>
        </header>

      {% comment %} one-group.liquid {% endcomment %}
      {% elsif OneGroup %}
        <header>
          <a href="/groups">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" height="30">
              <title>Go back to your groups</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M7.6 14L18.8 2.8L16 0L0 16L16 32L18.8 29.2L7.6 18H32V14H7.6Z" fill=""/>
            </svg>
          </a>
          <h1>{{ OneSnappMap.name }}</h1>
          <button>
            <svg height="30" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
              <title>Add Snappmap</title>
              <path id="Shape" fill-rule="evenodd" clip-rule="evenodd" d="M36 20.5714H20.5714V36H15.4286V20.5714H0V15.4286H15.4286V0H20.5714V15.4286H36V20.5714V20.5714Z" fill=""/>
            </svg>
          </button>
        </header>

      {% comment %} snappmaps.liquid {% endcomment %}
      {% elsif MultipleSnappMapslist %}
        <header class="items-2-top-nav-bar">
          <h1>Snappmaps</h1>
          <button>
            <svg height="30" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
              <title>Add Snappmap</title>
              <path id="Shape" fill-rule="evenodd" clip-rule="evenodd" d="M36 20.5714H20.5714V36H15.4286V20.5714H0V15.4286H15.4286V0H20.5714V15.4286H36V20.5714V20.5714Z" fill=""/>
            </svg>
          </button>
        </header>
      
      {% comment %} one-snappmap.liquid {% endcomment %}
      {% elsif OneSnappMap %}
        <header class="items-2-top-nav-bar">
          {% comment %} Make variable of the header name {% endcomment %}
          {% assign headerName = OneSnappMappInfo.name %}
          
          <details class="header-collapsible-list">
            <summary><h1>{{OneSnappMappInfo.name | truncate: 19 }} </h1></summary>

            {% comment %} List of names of other snappmaps in the same group {% endcomment %}
            {% for groups in OneSnappMappInfo.groups %}
              {% for snappmap in groups.snappthis_group_uuid.snappmap %}
                {% comment %} Make variable of other snappmap names {% endcomment %}
                {% assign listName = snappmap.snappthis_snapmap_uuid.name %}

                {% comment %} Check if a name of other snappmap is not the same as the header name, if it's not than show the name {% endcomment %}
                {% if snappmap.snappthis_snapmap_uuid.name != headerName %}
                  <ul>
                    <li><a href="/snappmaps/{{ snappmap.snappthis_snapmap_uuid.slug }}">{{ snappmap.snappthis_snapmap_uuid.name }}</a></li>
                  </ul> 
                {% endif %}
              {% endfor %}
            {% endfor %}
          </details>
          
          <button>
            <svg viewBox="0 0 37 37" xmlns="http://www.w3.org/2000/svg" height="30">
              <title>Change gridsize</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M0.894775 9.40015H9.89478V0.400146H0.894775V9.40015V9.40015ZM14.3948 36.4001H23.3948V27.4001H14.3948V36.4001V36.4001ZM0.894775 36.4001H9.89478V27.4001H0.894775V36.4001V36.4001ZM0.894775 22.9001H9.89478V13.9001H0.894775V22.9001V22.9001ZM14.3948 22.9001H23.3948V13.9001H14.3948V22.9001V22.9001ZM27.8948 0.400146V9.40015H36.8948V0.400146H27.8948V0.400146ZM14.3948 9.40015H23.3948V0.400146H14.3948V9.40015V9.40015ZM27.8948 22.9001H36.8948V13.9001H27.8948V22.9001V22.9001ZM27.8948 36.4001H36.8948V27.4001H27.8948V36.4001V36.4001Z" fill=""/>
            </svg>
          </button>
        </header>

      {% comment %} one-snapp.liquid {% endcomment %}
      {% elsif one_Snapp %}
        <header>
          <a href="/snappmaps/{% for OneSnapp in OneSnapps%}{{OneSnapp.snapmap.slug}}{% endfor %}">
              <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" height="30">
                <title>Go back to the Snappmap '{% for OneSnapp in OneSnapps%}{{OneSnapp.snapmap.name}}{% endfor %}'</title>
                <path fill-rule="evenodd" clip-rule="evenodd" d="M7.6 14L18.8 2.8L16 0L0 16L16 32L18.8 29.2L7.6 18H32V14H7.6Z" fill=""/>
              </svg>
          </a>
        
          <form action="" class="like-dislike-save-form">
              {% comment %} Like button {% endcomment %}
              <label>
                  {% for Likescount in Likescounts %}
                      <button>
                          <svg viewBox="0 0 26 24" xmlns="http://www.w3.org/2000/svg" height="30">
                              <title>Like this Snapp</title>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M11.18 22.1801C4.42 16.2001 0 12.1701 0 7.23008C0 3.20008 3.12 0.0800781 7.15 0.0800781C9.36 0.0800781 11.57 2.05608 13 3.74608C14.43 2.05608 16.64 0.0800781 18.85 0.0800781C22.88 0.0800781 26 3.20008 26 7.23008C26 12.1701 21.58 16.2001 14.82 22.1801L13 24.0001L11.18 22.1801Z" fill="#"/>
                          </svg>
                      </button>
                      <p>{{ Likescount.actions | size }}</p>
                  {% endfor %}
              </label>
            
              {% comment %} Dislike button {% endcomment %}
              <label>
                  {% for Tomatocount in Tomatocounts %}
                      <button>
                          <svg viewBox="0 0 25 26" xmlns="http://www.w3.org/2000/svg" height="30">
                              <title>Dislike this Snapp</title>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M13.4058 3.72573C13.8278 3.40698 14.3574 3.0832 14.9917 2.83616C16.1688 2.37764 17.9625 2.5135 19.9376 3.75587C19.9376 3.75587 18.8096 5.11737 17.6308 5.67973C16.5155 6.21178 15.9504 6.26072 15.76 6.27722L15.731 6.27981C16.5271 6.82259 17.2388 7.72723 17.6003 9.21083C17.6003 9.21083 15.8777 9.4264 14.802 9.02689C13.7263 8.62738 12.854 8.08004 12.3625 6.78038C12.3603 6.78742 12.3571 6.80485 12.3522 6.83125L12.3522 6.83129C12.3026 7.09881 12.0823 8.28695 11.0688 8.92738C9.95525 9.63107 8.72583 10.0371 7.50457 9.85011C7.42315 9.83805 7.57996 7.4287 9.69078 6.31298C9.57921 6.34012 8.65537 6.50379 7.36284 6.32203C6.07032 6.14026 4.9354 5.27566 4.1755 4.15994C4.11821 4.07249 6.81705 2.01294 9.80536 3.37894L9.80632 3.37941C9.84083 3.39631 10.7891 3.86081 11.5707 4.42144C11.6169 4.00824 11.72 3.38475 11.9495 2.61703C12.3774 1.18528 13.0928 0.0131043 13.0928 0.0131043L15.0185 0C15.0185 0 14.3365 0.747239 13.8811 2.01939C13.7055 2.50991 13.5413 3.13849 13.4058 3.72573ZM18.3084 6.9616C19.2513 8.72819 19.4199 10.3489 19.4199 10.3489C19.4199 10.3489 18.5626 10.7781 16.6085 10.724C14.9853 10.679 13.6024 10.2901 12.5699 9.48645C11.5462 10.699 10.1054 11.3612 8.39262 11.3612C8.03167 11.3612 7.65263 11.3325 7.27087 11.2728C6.63431 11.176 6.12952 10.6938 6.01584 10.0739C5.93171 9.60646 6.04418 8.67016 6.49922 7.68712C5.60815 7.42629 4.95892 7.22425 4.07841 6.30966C1.74927 8.48954 0 10.6278 0 13.9976C0 20.6252 5.59699 26 12.4997 26C19.403 26 24.9988 20.6255 24.9988 13.9976C24.9988 10.2774 22.9356 7.859 20.1692 5.65591C19.6792 6.14351 19.2513 6.46948 18.3084 6.9616Z" fill="#"/>
                          </svg>
                      </button>
                      <p>{{ Tomatocount.actions | size }}</p>
                  {% endfor %}
              </label>
            
              {% comment %} Star button {% endcomment %}
              <label>
                  {% for Starcount in Starcounts %}
                      <button>
                          <svg viewBox="0 0 38 36" xmlns="http://www.w3.org/2000/svg" height="30">
                              <title>Add this snap to favorites</title>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M18.9474 28.9383L30.6568 36L27.5589 22.6819L37.8947 13.7255L24.2697 12.5564L18.9474 0L13.6251 12.5564L0 13.7255L10.3358 22.6819L7.23789 36L18.9474 28.9383Z" fill="#"/>
                          </svg>
                      </button>
                      <p>{{ Starcount.actions | size }}</p>
                  {% endfor %}
              </label>
          </form>
        </header>
      
      {% comment %} capture-snapp.liquid {% endcomment %}
      {% elsif captureSnapp %}
        <header class="items-2-top-nav-bar">
          <a href="/snappmaps/{{ OneSnappMappName }}">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" height="30">
              <title>Go back to snappmap '{{ OneSnappMappName }}'</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M7.6 14L18.8 2.8L16 0L0 16L16 32L18.8 29.2L7.6 18H32V14H7.6Z" fill=""/>
            </svg>
          </a>
          {% comment %} <h1>Capture Snapp</h1> {% endcomment %}
        </header>
      
      {% comment %} snapps.liquid {% endcomment %}
      {% elsif path %}
        <header class="items-2-top-nav-bar">
          <h1>Snapps</h1>

          <button>
            <svg viewBox="0 0 37 37" xmlns="http://www.w3.org/2000/svg" height="30">
              <title>Change gridsize</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M0.894775 9.40015H9.89478V0.400146H0.894775V9.40015V9.40015ZM14.3948 36.4001H23.3948V27.4001H14.3948V36.4001V36.4001ZM0.894775 36.4001H9.89478V27.4001H0.894775V36.4001V36.4001ZM0.894775 22.9001H9.89478V13.9001H0.894775V22.9001V22.9001ZM14.3948 22.9001H23.3948V13.9001H14.3948V22.9001V22.9001ZM27.8948 0.400146V9.40015H36.8948V0.400146H27.8948V0.400146ZM14.3948 9.40015H23.3948V0.400146H14.3948V9.40015V9.40015ZM27.8948 22.9001H36.8948V13.9001H27.8948V22.9001V22.9001ZM27.8948 36.4001H36.8948V27.4001H27.8948V36.4001V36.4001Z" fill=""/>
            </svg>
          </button>
        </header>
      
      {% comment %} All snapps in 1 location {% endcomment %}
      {% elsif pathLocation %}
        <header class="items-2-top-nav-bar">
          {% for OneSnapp in MultipleSnapps limit: 1 %}
            <h1>{{ OneSnapp.location}}</h1>
          {% endfor %}
          
          <button>
            <svg viewBox="0 0 37 37" xmlns="http://www.w3.org/2000/svg" height="30">
              <title>Change gridsize</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M0.894775 9.40015H9.89478V0.400146H0.894775V9.40015V9.40015ZM14.3948 36.4001H23.3948V27.4001H14.3948V36.4001V36.4001ZM0.894775 36.4001H9.89478V27.4001H0.894775V36.4001V36.4001ZM0.894775 22.9001H9.89478V13.9001H0.894775V22.9001V22.9001ZM14.3948 22.9001H23.3948V13.9001H14.3948V22.9001V22.9001ZM27.8948 0.400146V9.40015H36.8948V0.400146H27.8948V0.400146ZM14.3948 9.40015H23.3948V0.400146H14.3948V9.40015V9.40015ZM27.8948 22.9001H36.8948V13.9001H27.8948V22.9001V22.9001ZM27.8948 36.4001H36.8948V27.4001H27.8948V36.4001V36.4001Z" fill=""/>
            </svg>
          </button>
        </header>
    {% endif %}
    <main>