{% render 'partials/head.liquid', title: 'Capture Snapp', captureSnapp: true, oneSnappMappName: oneSnappMapp.slug %}

<section class="capture-snap-page">
  <img id="display-image" src="/assets/grey-background-placeholder.jpg" width="40%">

  <h2>{{ oneSnappMapp.name }}</h2>

  <form method="POST" action="/snappmaps/{{ oneSnappMapp.slug}}" enctype="multipart/form-data">
    <input id="upload-snapp" type="file" name="file" capture="environment" required accept="image/*">

    {% comment %} Capture button {% endcomment %}
    <label for="upload-snapp" class="upload-snap add-snapp-link-button capture-button">
      <svg viewBox="0 0 43 36" xmlns="http://www.w3.org/2000/svg" height="30">
          <title>Capture snapp</title>
