      </svg>
    </label>

    {% comment %} Recapture button {% endcomment %}
    <label for="upload-snapp" class="redo-button is-hidden">
      <svg height="30" viewBox="0 0 69 69" xmlns="http://www.w3.org/2000/svg" fill="">
        <title>Recapture snapp</title>
